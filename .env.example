# Copy this file to `.env` and fill in your machine-specific values.
# `.env` is gitignored. `install.sh` auto-sources it if present.

# Absolute path to your Obsidian Vault.
VAULT_PATH="$HOME/MyVault"

# Optional: where to place the per-run git worktree. Must be OUTSIDE iCloud
# Drive — the worktree holds the agent's intermediate writes and merging
# them with iCloud sync would race.
# Default: $HOME/Workspace/vault-workbench
WORKBENCH_DIR="$HOME/Workspace/vault-workbench"

# Optional: where to place the runtime Python virtualenv. Must be OUTSIDE
# iCloud Drive — venvs contain many small binaries that iCloud can corrupt
# or quarantine.
# Default: $HOME/Library/Application Support/vault-organizer/venv
# VENV_DIR="$HOME/Library/Application Support/vault-organizer/venv"

# Optional: colon-separated list of repository basenames that
# `project_sync.py` should skip when run in bulk mode (parent directory
# containing several repos). Single-target invocations
# (`project_sync.py ~/Projects/<name>`) ignore this list so an explicitly
# named repo always syncs. The value is baked into the Vault's
# `config_local.py` by `install.sh`, so editing this and re-running
# `install.sh` is enough — no shell export needed at run time.
# A runtime `PROJECT_SYNC_IGNORE=...` env var still works as a one-off
# override.
# PROJECT_SYNC_IGNORE="_Vault:scratch:dotfiles"
